NODE_ENV=production
PORT=4001

# Set true only if Node server itself should terminate TLS.
# Recommended on EC2: keep false and terminate TLS at Nginx/ALB.
ENABLE_HTTPS=false
FORCE_HTTP_TO_HTTPS=false
HTTP_PORT=80
CERT_KEY_PATH=./certs/key.pem
CERT_PATH=./certs/cert.pem

# Frontend origins allowed by CORS (comma-separated)
# Example: https://your-app.vercel.app,https://app.yourdomain.com
CORS_ORIGIN=https://project-network-e2ee-cloud.vercel.app

JWT_SECRET=change_this_to_a_strong_secret
SOCKET_IO_PATH=/ws

DB_HOST=pj-cloud.cfkywcoom7ye.ap-southeast-7.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your_password
DB_NAME=pj_network
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
# Optional: set RDS CA bundle path and set DB_SSL_REJECT_UNAUTHORIZED=true for strict validation
# DB_SSL_CA_PATH=/var/www/project-network-e2ee-cloud/backend/rds-ca-bundle.pem
