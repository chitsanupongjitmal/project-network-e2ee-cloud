# Backend public URL reachable from browser
# Example: https://api.yourdomain.com
# Leave empty when using Vercel rewrites (/api and /socket.io)
VITE_SERVER_URL=

# Optional dedicated Socket.IO URL for true websocket.
# Example: wss://api.yourdomain.com
# If empty, frontend will use VITE_SERVER_URL, then fallback to same-origin rewrite mode.
VITE_SOCKET_URL=

# Socket.IO path used by client and backend. Recommended: /api/ws
VITE_SOCKET_PATH=/api/ws
